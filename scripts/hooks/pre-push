#!/bin/bash
set -e

echo "Running pre-push gates..."

# Run unit/compile tests without DB, mirroring the CI 'test' job which has no
# DUBBRIDGE_DATABASE_URL. Integration tests self-skip when the var is absent,
# matching CI behaviour and avoiding parallel-DB race conditions in qa-test.
DUBBRIDGE_DATABASE_URL= make qa-test

make qa-maintainability

if [ -d mobile/node_modules ]; then
    echo "Running mobile gate..."
    make qa-mobile
else
    echo "WARNING: mobile/node_modules missing — skipping mobile gate."
    echo "  To enable: (cd mobile && npm ci)"
fi

if [ -n "$DUBBRIDGE_DATABASE_URL" ]; then
    echo "Running coverage with DB..."
    make qa-coverage
else
    echo "ERROR: DUBBRIDGE_DATABASE_URL not set — integration tests require a live database."
    echo "  export DUBBRIDGE_DATABASE_URL=postgresql://dubbridge:dubbridge@localhost:5432/dubbridge_test"
    echo "  docker compose -f infra/local/docker-compose.yml up -d postgres"
    exit 1
fi

echo "Pre-push gates passed."
