#!/bin/bash
set -e

echo "Running pre-push gates..."
make qa-test
make qa-maintainability

if [ -d mobile/node_modules ]; then
    echo "Running mobile gate..."
    make qa-mobile
else
    echo "WARNING: mobile/node_modules missing — skipping mobile gate."
    echo "  To enable: (cd mobile && npm ci)"
fi

if [ -n "$DUBBRIDGE_DATABASE_URL" ]; then
    echo "Running coverage with DB..."
    make qa-coverage
else
    echo "WARNING: DUBBRIDGE_DATABASE_URL not set — skipping coverage gate."
    echo "  To enable: export DUBBRIDGE_DATABASE_URL=postgresql://dubbridge:dubbridge@localhost:5432/dubbridge_test"
    echo "  Then spin up Postgres: docker compose -f infra/local/docker-compose.yml up -d postgres"
fi

echo "Pre-push gates passed."
