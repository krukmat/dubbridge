{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'WORKFLOW CHECK: (1) presented task? (2) ran scripts/rri.py? (3) explicit approval received (RRI 26+)? (4) Reflection passes planned (Moderate=2, Med-high=3, Complex=4)? See docs/playbooks/AGENT_WORKFLOW_GUIDE.md' >&2"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(make qa-docs *)",
      "Bash(make qa-docs)",
      "Bash(make qa-okf-frontmatter)",
      "Bash(make qa-rri)",
      "Bash(adb devices *)",
      "Bash(adb devices)",
      "Bash(adb -s emulator-5554 reverse *)",
      "Bash(adb -s emulator-5554 shell am start *)",
      "Bash(adb -s emulator-5554 shell am force-stop *)",
      "Bash(adb -s emulator-5554 install *)",
      "Bash(adb install *)",
      "Bash(adb logcat *)",
      "Bash(adb shell *)",
      "Bash(bash mobile/maestro/seed-and-run.sh)",
      "Bash(bash mobile/maestro/seed-and-run.sh *)",
      "Bash(npm test -- *)",
      "Bash(npm run typecheck)",
      "Bash(cargo test *)",
      "Bash(cargo fmt *)",
      "Bash(cargo clippy *)",
      "Bash(cargo check *)",
      "Bash(cargo llvm-cov *)",
      "Bash(docker compose *)",
      "Bash(docker ps *)",
      "Bash(docker ps)",
      "Bash(xcrun simctl *)",
      "Bash(curl -sf *)",
      "Bash(curl -s *)",
      "Bash(curl -v *)"
    ]
  }
}
